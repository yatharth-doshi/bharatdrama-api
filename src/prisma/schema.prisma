// Prisma Schema for BharatDrama Streaming Platform
// OTT Platform Backend Database Schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum ContentType {
  MOVIE
  SERIES
  SPECIAL
}

enum VideoQuality {
  SD_360P
  HD_720P
  FHD_1080P
  AUTO
}

enum DownloadStatus {
  PENDING
  DOWNLOADING
  COMPLETED
  FAILED
  PAUSED
}

enum NotificationType {
  NEW_CONTENT
  SUBSCRIPTION_ALERT
  PAYMENT_REMINDER
  GENERAL
  OFFER
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PromotionType {
  BANNER
  SIDEBAR
  POPUP
  IN_STREAM
}

enum ReactionType {
  LIKE
  DISLIKE
}

// ==================== USERS MANAGEMENT ====================

model User {
  id                    String                   @id @default(cuid())
  email                 String                   @unique
  phone                 String?                  @unique
  firstName             String
  lastName              String
  passwordHash          String?
  role                  UserRole                 @default(USER)
  profilePicture        String?
  isActive              Boolean                  @default(true)
  isBlocked             Boolean                  @default(false)
  lastLogin             DateTime?
  loginCount            Int                      @default(0)
  emailVerified         Boolean                  @default(false)
  phoneVerified         Boolean                  @default(false)
  twoFactorEnabled      Boolean                  @default(false)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?

  // Relations
  profiles              Profile[]
  socialAuths           SocialAuth[]
  subscriptions         Subscription[]
  payments              Payment[]
  watchHistory          WatchHistory[]
  downloads             Download[]
  notifications         Notification[]
  ratings               Rating[]
  reviews               Review[]
  adminLogs             AdminLog[]
  watchlists            Watchlist[]
  searchHistories       SearchHistory[]
  tasteProfiles         UserTasteProfile[]
  supportTickets        SupportTicket[]
  reactions             Reaction[]

  @@index([email])
  @@index([phone])
  @@index([isActive])
}

model SocialAuth {
  id                String     @id @default(cuid())
  userId            String
  provider          String     // 'google', 'facebook'
  providerUserId    String
  email             String?
  name              String?
  accessToken       String?
  refreshToken      String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

// ==================== PROFILES ====================

model Profile {
  id                String     @id @default(cuid())
  userId            String
  name              String
  avatarUrl         String?
  isKidsProfile     Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  watchHistory      WatchHistory[]
  downloads         Download[]
  watchlists        Watchlist[]
  searchHistories   SearchHistory[]
  tasteProfile      UserTasteProfile?
  reactions         Reaction[]

  pin               String?    // For Parental Control (Netflix-style)

  @@index([userId])
}

// ==================== CONTENT MANAGEMENT ====================

model Content {
  id                String     @id @default(cuid())
  title             String
  description       String?    @db.Text
  contentType       ContentType
  posterUrl         String?
  bannerUrl         String?
  trailerUrl        String?
  releaseDate       DateTime?
  isAdult           Boolean    @default(false)
  isActive          Boolean    @default(true)
  viewCount         Int        @default(0)
  averageRating     Float      @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  genres            Genre[]
  languages         Language[]
  cast              Cast[]
  directors         Director[]
  videos            Video[]
  watchHistory      WatchHistory[]
  downloads         Download[]
  ratings           Rating[]
  reviews           Review[]
  recommendations   Recommendation[]
  subscriptionPlans SubscriptionPlanContent[]
  watchlists        Watchlist[]
  reactions         Reaction[]
  promotions        PromotionContent[]

  isFeatured        Boolean    @default(false)
  trendingScore     Float      @default(0)

  @@index([contentType])
  @@index([isActive])
  @@index([releaseDate])
}

model Genre {
  id                String     @id @default(cuid())
  name              String     @unique
  description       String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  contents          Content[]
}

model Language {
  id                String     @id @default(cuid())
  name              String     @unique
  code              String     @unique
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  contents          Content[]
  subtitles         Subtitle[]
}

model Cast {
  id                String     @id @default(cuid())
  name              String
  role              String
  profileImageUrl   String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  contents          Content[]
}

model Director {
  id                String     @id @default(cuid())
  name              String
  bio               String?    @db.Text
  profileImageUrl   String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  contents          Content[]
}

// ==================== VIDEOS & STREAMING ====================

model Video {
  id                String     @id @default(cuid())
  contentId         String
  episodeNumber     Int?       // For series
  seasonNumber      Int?       // For series
  title             String
  description       String?    @db.Text
  duration          Int        // In seconds
  s3Url             String
  cloudFrontUrl     String?
  thumbnailUrl      String?
  subtitles         Subtitle[]
  audioTracks       AudioTrack[]
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  content           Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  watchHistories    WatchHistory[]

  @@index([contentId])
  @@index([episodeNumber, seasonNumber])
}

model Subtitle {
  id                String     @id @default(cuid())
  videoId           String
  languageId        String
  fileUrl           String
  format            String     // 'srt', 'vtt'
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  video             Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)
  language          Language   @relation(fields: [languageId], references: [id])

  @@unique([videoId, languageId])
}

model AudioTrack {
  id                String     @id @default(cuid())
  videoId           String
  languageId        String
  fileUrl           String
  isDefault         Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  video             Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

// ==================== WATCH HISTORY ====================

model WatchHistory {
  id                String     @id @default(cuid())
  userId            String
  profileId         String
  contentId         String
  videoId           String
  watchedDuration   Int        // In seconds
  totalDuration     Int        // In seconds
  watchedAt         DateTime   @default(now())
  completedAt       DateTime?
  isCompleted       Boolean    @default(false)

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile           Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content           Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)
  video             Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, profileId, videoId])
  @@index([userId])
  @@index([profileId])
  @@index([contentId])
}

// ==================== DOWNLOADS ====================

model Download {
  id                String     @id @default(cuid())
  userId            String
  profileId         String
  contentId         String
  quality           VideoQuality @default(AUTO)
  status            DownloadStatus @default(PENDING)
  downloadedSize    Int?       // In bytes
  totalSize         Int?       // In bytes
  downloadPath      String?
  expiresAt         DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile           Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content           Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

// ==================== SUBSCRIPTIONS ====================

model SubscriptionPlan {
  id                String     @id @default(cuid())
  name              String
  description       String?    @db.Text
  monthlyPrice      Float
  yearlyPrice       Float?
  maxProfiles       Int        @default(1)
  maxConcurrentStreams Int     @default(1)
  maxQuality        VideoQuality @default(FHD_1080P)
  isAdFree          Boolean    @default(false)
  isDownloadEnabled Boolean    @default(false)
  maxDownloads      Int        @default(0)
  isActive          Boolean    @default(true)
  displayOrder      Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  subscriptions     Subscription[]
  contents          SubscriptionPlanContent[]

  @@index([isActive])
}

model SubscriptionPlanContent {
  id                String     @id @default(cuid())
  planId            String
  contentId         String
  createdAt         DateTime   @default(now())

  plan              SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  content           Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([planId, contentId])
}

model Subscription {
  id                String     @id @default(cuid())
  userId            String
  planId            String
  status            SubscriptionStatus @default(PENDING)
  startDate         DateTime   @default(now())
  endDate           DateTime
  renewalDate       DateTime?
  isAutoRenew       Boolean    @default(true)
  cancellationDate  DateTime?
  cancellationReason String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan @relation(fields: [planId], references: [id])
  payments          Payment[]

  @@index([userId])
  @@index([status])
  @@index([endDate])
}

// ==================== PAYMENTS ====================

model Payment {
  id                String     @id @default(cuid())
  userId            String
  subscriptionId    String
  amount            Float
  currency          String    @default("INR")
  paymentMethod     String    // 'razorpay', 'stripe', 'upi'
  transactionId     String?
  status            PaymentStatus @default(PENDING)
  failureReason     String?
  refundAmount      Float?
  refundDate        DateTime?
  receiptUrl        String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription      Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([transactionId])
}

// ==================== RATINGS & REVIEWS ====================

model Rating {
  id                String     @id @default(cuid())
  userId            String
  contentId         String
  rating            Int        // 1-5
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content           Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@index([contentId])
}

model Review {
  id                String     @id @default(cuid())
  userId            String
  contentId         String
  title             String
  description       String?    @db.Text
  helpful           Int        @default(0)
  notHelpful        Int        @default(0)
  isApproved        Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content           Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([isApproved])
}

// ==================== RECOMMENDATIONS ====================

model Recommendation {
  id                String     @id @default(cuid())
  contentId         String
  recommendedContentId String
  score             Float      @default(0)
  reason            String?    // 'trending', 'genre-based', 'similar-cast'
  createdAt         DateTime   @default(now())

  content           Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId])
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id                String     @id @default(cuid())
  userId            String
  type              NotificationType
  title             String
  message           String    @db.Text
  isRead            Boolean    @default(false)
  actionUrl         String?
  createdAt         DateTime   @default(now())
  readAt            DateTime?

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ==================== ADMIN LOGS ====================

model AdminLog {
  id                String     @id @default(cuid())
  adminId           String
  action            String     // 'create', 'update', 'delete'
  entityType        String     // 'user', 'content', 'subscription'
  entityId          String
  changes           Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime   @default(now())

  admin             User       @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([entityType])
  @@index([createdAt])
}

// ==================== NEW OTT FEATURES ====================

model Watchlist {
  id                String     @id @default(cuid())
  userId            String
  profileId         String
  contentId         String
  createdAt         DateTime   @default(now())

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile           Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content           Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
  @@index([userId])
}

model SearchHistory {
  id                String     @id @default(cuid())
  userId            String
  profileId         String
  query             String
  createdAt         DateTime   @default(now())

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile           Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId, profileId])
}

model UserTasteProfile {
  id                    String     @id @default(cuid())
  userId                String
  profileId             String     @unique
  genrePreferences      Json?      // e.g. { "Action": 0.8, "Romance": 0.2 }
  actorPreferences      Json?
  languagePreferences   Json?
  watchTimePatterns     Json?      // e.g. { "Night": 0.7, "Day": 0.3 }
  updatedAt             DateTime   @updatedAt

  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile               Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SupportTicket {
  id                String               @id @default(cuid())
  userId            String
  subject           String
  description       String               @db.Text
  status            SupportTicketStatus  @default(OPEN)
  priority          SupportTicketPriority @default(MEDIUM)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Reaction {
  id                String       @id @default(cuid())
  userId            String
  profileId         String
  contentId         String
  type              ReactionType // LIKE, DISLIKE
  createdAt         DateTime     @default(now())

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile           Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  content           Content      @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([profileId, contentId])
  @@index([userId])
}

model Promotion {
  id                String           @id @default(cuid())
  title             String
  description       String?          @db.Text
  promotionType     PromotionType
  imageUrl          String?
  actionUrl         String?
  startDate         DateTime
  endDate           DateTime
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  contents          PromotionContent[]

  @@index([isActive])
  @@index([startDate, endDate])
}

model PromotionContent {
  id                String     @id @default(cuid())
  promotionId       String
  contentId         String
  createdAt         DateTime   @default(now())

  promotion         Promotion  @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  content           Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([promotionId, contentId])
}
